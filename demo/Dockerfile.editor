FROM python:3.12-slim
WORKDIR /app
COPY . /app
RUN pip install --no-cache-dir ".[editor]"
# Pre-place release notebooks in workspace
RUN mkdir -p workspace && \
    cp demo/course/demo-assignment/files/*.py workspace/ && \
    cp demo/course/demo-holistic/files/*.py workspace/
CMD python -m marimo edit workspace/ --sandbox --no-token --host 0.0.0.0 --port ${PORT:-8080}
