FROM python:3.12-slim
WORKDIR /app
COPY . /app
RUN pip install --no-cache-dir uv ".[grader,asgi]"
RUN bash demo/setup_formgrader_demo.sh
ENV MOGRADER_COURSE_DIR=/app/demo/formgrader-course
ENV MOGRADER_SERVE_DIR=/app/demo/formgrader-course/release
CMD python -m uvicorn demo.demo_app:app --host 0.0.0.0 --port ${PORT:-8080}
